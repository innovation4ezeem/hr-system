  popularity_15         Decimal?                       @default(0.00) @db.Decimal(6, 2)
  raw_score             Decimal?                       @default(0.00) @db.Decimal(6, 2)
  penalty_deduction     Decimal?                       @default(0.00) @db.Decimal(6, 2)
  final_score           Decimal?                       @default(0.00) @db.Decimal(6, 2)
