  calculated_at         DateTime?                      @db.DateTime(0)
  approved_by           String?                        @db.VarChar(255)
  approved_at           DateTime?                      @db.DateTime(0)
  created_at            DateTime?                      @default(now()) @db.DateTime(0)
  updated_at            DateTime?                      @default(now()) @db.DateTime(0)
  users                 users                          @relation(fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "performance_scores_ibfk_1")

  @@index([employee_id], map: "employee_id")
}

model performance_sheets {
  year          Int       @id
  columns_json  Json?     @default(dbgenerated("(json_array())"))
  sections_json Json?     @default(dbgenerated("(json_array())"))
  cells_json    Json?     @default(dbgenerated("(json_object())"))
  updated_at    DateTime? @default(now()) @db.DateTime(0)
}

model profile_update_requests {
  id                                               String                          @id @db.VarChar(255)
  employee_id                                      String                          @db.VarChar(255)
  requested_changes                                Json
  status                                           profile_update_requests_status? @default(pending)
  reviewed_by                                      String?                         @db.VarChar(255)
  reviewed_at                                      DateTime?                       @db.DateTime(0)
  review_comment                                   String?                         @db.Text
  created_at                                       DateTime?                       @default(now()) @db.DateTime(0)
  updated_at                                       DateTime?                       @default(now()) @db.DateTime(0)
  users_profile_update_requests_employee_idTousers users                           @relation("profile_update_requests_employee_idTousers", fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profile_update_requests_ibfk_1")
  users_profile_update_requests_reviewed_byTousers users?                          @relation("profile_update_requests_reviewed_byTousers", fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profile_update_requests_ibfk_2")

  @@index([employee_id], map: "employee_id")
  @@index([reviewed_by], map: "reviewed_by")
