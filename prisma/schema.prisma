  quality_errors      Decimal?                       @default(0.00) @db.Decimal(10, 2)
  participation_json  Json?
  popularity_json     Json?
  updated_by          String?                        @db.VarChar(255)
  created_at          DateTime?                      @default(now()) @db.DateTime(0)
  updated_at          DateTime?                      @default(now()) @db.DateTime(0)
  users               users                          @relation(fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "performance_inputs_ibfk_1")

