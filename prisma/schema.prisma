model profiles {
  id              String                    @id @db.VarChar(255)
  employee_id     String?                   @db.VarChar(50)
  full_name       String?                   @db.VarChar(255)
  phone_number    String?                   @db.VarChar(20)
  department      String?                   @db.VarChar(100)
  role            profiles_role?
  join_date       DateTime?                 @db.Date
  preferred_theme profiles_preferred_theme? @default(light)
  reports_to_id   String?                   @db.VarChar(255)
  created_at      DateTime?                 @default(now()) @db.DateTime(0)
  updated_at      DateTime?                 @default(now()) @db.DateTime(0)
  users           users?                    @relation(fields: [reports_to_id], references: [id], onUpdate: NoAction, map: "profiles_ibfk_1")

  @@index([reports_to_id], map: "reports_to_id")
}

model scoring_categories {
  year          Int
  id            String    @db.VarChar(100)
  name          String    @db.VarChar(255)
  weight        Int?      @default(0)
  description   String?   @db.Text
  color         String?   @db.VarChar(50)
  display_order Int?      @default(0)
  created_at    DateTime? @default(now()) @db.DateTime(0)
  updated_at    DateTime? @default(now()) @db.DateTime(0)

  @@id([year, id])
}

model self_evaluations {
  id           String    @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  employee_id  String    @db.VarChar(255)
  period_label String    @db.VarChar(50)
  reflection   String?   @db.Text
  hod_comment  String?   @db.Text
  saved_at     DateTime? @default(now()) @db.DateTime(0)
  users        users     @relation(fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "self_evaluations_ibfk_1")

  @@index([employee_id], map: "employee_id")
}

model system_audit_logs {
  log_id       BigInt    @id @default(autoincrement())
  event_type   String    @db.VarChar(100)
  action       String    @db.VarChar(100)
  actor        String?   @default("system") @db.VarChar(255)
  payload_json Json?
  created_at   DateTime? @default(now()) @db.DateTime(0)
}

model system_settings {
  setting_key  String   @id @db.VarChar(255)
  setting_json Json?
  updated_at   DateTime @default(now()) @db.DateTime(0)
}

model users {
  id                                                                 String                              @id @db.VarChar(255)
  name                                                               String                              @db.VarChar(255)
  email                                                              String                              @unique(map: "email") @db.VarChar(255)
  role                                                               users_role
  dept                                                               String                              @default("") @db.VarChar(100)
  status                                                             users_status                        @default(active)
  join_date                                                          String                              @default("") @db.VarChar(50)
  password                                                           String?                             @db.VarChar(255)
  created_at                                                         DateTime?                           @default(now()) @db.DateTime(0)
  updated_at                                                         DateTime?                           @default(now()) @db.DateTime(0)
  reports_to_id                                                      String?                             @db.VarChar(255)
  profile_update_status                                              users_profile_update_status?        @default(approved)
  phone                                                              String?                             @db.VarChar(20)
  address                                                            String?                             @db.Text
  emergency_contact                                                  String?                             @db.Text
  preferred_name                                                     String?                             @db.VarChar(100)
  bank_details                                                       String?                             @db.Text
  preferred_theme                                                    users_preferred_theme?
  rewards                                                            Json?
  achievements                                                       Json?
  experience_in_office                                               Json?
  mailing_address                                                    String?                             @db.Text
  phone_number                                                       String?                             @db.VarChar(20)
  department_id                                                      String?                             @db.VarChar(100)
  employee_leave_attendance_records                                  employee_leave_attendance_records[]
  employee_leave_entitlements                                        employee_leave_entitlements[]
  employee_service_years                                             employee_service_years?
  evaluation_attachments                                             evaluation_attachments[]
  leave_balances                                                     leave_balances[]
  leave_requests                                                     leave_requests[]
  notifications                                                      notifications[]
  penalties                                                          penalties[]
  performance_comments                                               performance_comments[]
  performance_inputs                                                 performance_inputs[]
  performance_scores                                                 performance_scores[]
  profile_update_requests_profile_update_requests_employee_idTousers profile_update_requests[]           @relation("profile_update_requests_employee_idTousers")
  profile_update_requests_profile_update_requests_reviewed_byTousers profile_update_requests[]           @relation("profile_update_requests_reviewed_byTousers")
  profiles                                                           profiles[]
  self_evaluations                                                   self_evaluations[]
  users                                                              users?                              @relation("usersTousers", fields: [reports_to_id], references: [id], onUpdate: NoAction, map: "users_ibfk_1")
  other_users                                                        users[]                             @relation("usersTousers")

  @@index([reports_to_id], map: "reports_to_id")
}

